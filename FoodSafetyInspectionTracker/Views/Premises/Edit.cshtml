@model FoodSafetyInspectionTracker.Models.Premises

@{
    ViewData["Title"] = "Edit Premises";
}

<h1>Edit Premises</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Address" class="form-label"></label>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Town" class="form-label"></label>
        <input asp-for="Town" class="form-control" />
        <span asp-validation-for="Town" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="RiskRating" class="form-label"></label>
        <select asp-for="RiskRating" class="form-control" asp-items="Html.GetEnumSelectList<FoodSafetyInspectionTracker.Models.Enums.RiskRating>()"></select>
        <span asp-validation-for="RiskRating" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>