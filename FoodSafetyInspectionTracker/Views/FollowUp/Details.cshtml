@model FoodSafetyInspectionTracker.Models.FollowUp

@{
    ViewData["Title"] = "Follow Up Details";
}

<h1>Follow Up Details</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">Inspection</dt>
        <dd class="col-sm-10">@Model.InspectionId</dd>

        <dt class="col-sm-2">Premises</dt>
        <dd class="col-sm-10">@Model.Inspection?.Premises?.Name</dd>

        <dt class="col-sm-2">Due Date</dt>
        <dd class="col-sm-10">@Model.DueDate.ToShortDateString()</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>

        <dt class="col-sm-2">Closed Date</dt>
        <dd class="col-sm-10">@(Model.ClosedDate?.ToShortDateString() ?? "-")</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>