@model FoodSafetyInspectionTracker.Models.Inspection

@{
    ViewData["Title"] = "Edit Inspection";
}

<h1>Edit Inspection</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="PremisesId" class="form-label"></label>
        <select asp-for="PremisesId" class="form-control" asp-items="ViewBag.PremisesId"></select>
        <span asp-validation-for="PremisesId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="InspectionDate" class="form-label"></label>
        <input asp-for="InspectionDate" type="date" class="form-control" />
        <span asp-validation-for="InspectionDate" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Score" class="form-label"></label>
        <input asp-for="Score" class="form-control" />
        <span asp-validation-for="Score" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Outcome" class="form-label"></label>
        <select asp-for="Outcome" class="form-control" asp-items="Html.GetEnumSelectList<FoodSafetyInspectionTracker.Models.Enums.InspectionOutcome>()"></select>
        <span asp-validation-for="Outcome" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <input asp-for="Notes" class="form-control" />
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>