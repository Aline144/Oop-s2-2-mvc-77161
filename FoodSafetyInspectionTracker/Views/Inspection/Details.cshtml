@model FoodSafetyInspectionTracker.Models.Inspection

@{
    ViewData["Title"] = "Inspection Details";
}

<h1>Inspection Details</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">Premises</dt>
        <dd class="col-sm-10">@Model.Premises?.Name</dd>

        <dt class="col-sm-2">Inspection Date</dt>
        <dd class="col-sm-10">@Model.InspectionDate.ToShortDateString()</dd>

        <dt class="col-sm-2">Score</dt>
        <dd class="col-sm-10">@Model.Score</dd>

        <dt class="col-sm-2">Outcome</dt>
        <dd class="col-sm-10">@Model.Outcome</dd>

        <dt class="col-sm-2">Notes</dt>
        <dd class="col-sm-10">@Model.Notes</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>