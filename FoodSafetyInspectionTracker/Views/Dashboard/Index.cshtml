@model FoodSafetyInspectionTracker.ViewModels.DashboardViewModel
@using FoodSafetyInspectionTracker.Models.Enums

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<form method="get" asp-action="Index" class="mb-4">
    <div class="row">
        <div class="col-md-4 mb-3">
            <label for="selectedTown" class="form-label">Town</label>
            <select id="selectedTown" name="selectedTown" class="form-control">
                <option value="">All Towns</option>
                @foreach (var town in Model.Towns)
                {
                    if (Model.SelectedTown == town)
                    {
                        <option value="@town" selected>@town</option>
                    }
                    else
                    {
                        <option value="@town">@town</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-4 mb-3">
            <label for="selectedRiskRating" class="form-label">Risk Rating</label>
            <select id="selectedRiskRating" name="selectedRiskRating" class="form-control">
                <option value="">All Risk Ratings</option>
                @foreach (var rating in Enum.GetValues(typeof(RiskRating)).Cast<RiskRating>())
                {
                    if (Model.SelectedRiskRating == rating)
                    {
                        <option value="@rating" selected>@rating</option>
                    }
                    else
                    {
                        <option value="@rating">@rating</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-4 mb-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">Apply Filters</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </div>
    </div>
</form>

<div class="row">
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card p-3">
            <h5>Inspections This Month</h5>
            <p class="fs-3">@Model.InspectionsThisMonth</p>
        </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card p-3">
            <h5>Failed Inspections This Month</h5>
            <p class="fs-3">@Model.FailedInspectionsThisMonth</p>
        </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card p-3">
            <h5>Open Follow Ups</h5>
            <p class="fs-3">@Model.OpenFollowUps</p>
        </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card p-3">
            <h5>Overdue Follow Ups</h5>
            <p class="fs-3">@Model.OverdueFollowUps</p>
        </div>
    </div>
</div>